# =============================================================================
# Tandava Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# See docs/developer/setup.md for detailed setup instructions.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (Required)
# -----------------------------------------------------------------------------
# Get these from: https://supabase.com/dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# -----------------------------------------------------------------------------
# Stripe (Required for payments)
# -----------------------------------------------------------------------------
# Get these from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here
# Server-side only (used in Supabase Edge Functions, NOT in frontend)
# STRIPE_SECRET_KEY=sk_test_your-key-here
# STRIPE_WEBHOOK_SECRET=whsec_your-secret-here

# -----------------------------------------------------------------------------
# Sentry (Optional - error monitoring)
# -----------------------------------------------------------------------------
# Get these from: https://sentry.io → Project Settings → Client Keys (DSN)
VITE_SENTRY_DSN=
# Used only at build time for source map upload
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=

# -----------------------------------------------------------------------------
# Email Provider (Configured in Supabase Edge Functions)
# -----------------------------------------------------------------------------
# Provider: "resend" | "sendgrid" | "smtp" | "console"
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_your-key-here
# SENDGRID_API_KEY=SG.your-key-here
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=noreply@your-studio.com
# EMAIL_FROM_NAME=Your Studio Name

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
VITE_APP_URL=http://localhost:8080
VITE_APP_NAME=Tandava

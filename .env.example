# Tandava Environment Configuration
# Copy this file to .env.local and fill in values

# =============================================================================
# DEMO MODE (no database required)
# =============================================================================
# Set to "true" to run with mock data (Oxatl Yoga demo studio)
VITE_DEMO_MODE=true

# =============================================================================
# SUPABASE (required for production, optional for demo mode)
# =============================================================================
# Get these from your Supabase project dashboard or local CLI output
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# =============================================================================
# STRIPE (required for payment processing)
# =============================================================================
# Get these from your Stripe dashboard
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# =============================================================================
# OPTIONAL
# =============================================================================
# Custom port (default: 8080)
# VITE_PORT=8080
